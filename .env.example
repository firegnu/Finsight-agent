# --- Chat LLM (multi-provider) ---
# Add more providers by declaring another XXX_LABEL / XXX_BASE_URL / XXX_API_KEY / XXX_MODEL group
# and registering the id in backend/config.py PROVIDER_IDS.

# Default provider used when the frontend/request omits provider_id.
DEFAULT_PROVIDER_ID=zhipu

# Provider 1: Local LM Studio (offline / LAN-only)
LMSTUDIO_LABEL=本地 LM Studio (GLM-4.7-Flash)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=zai-org/glm-4.7-flash

# Provider 2: Zhipu BigModel cloud (free GLM-4.7-Flash, 1 concurrent)
ZHIPU_LABEL=智谱云 GLM-4.7-Flash
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4.7-flash

MAX_AGENT_STEPS=10

# --- Embedding (RAG) ---
# Embedding stays locked to a single provider: the Chroma vector space is
# bound to the embedding model used at index time. Changing it requires
# rebuilding the index (python scripts/index_cases.py).
#
# SiliconFlow bge-m3 (recommended): free, 1024-dim, OpenAI-compatible.
#   https://api.siliconflow.cn/v1
# Local LM Studio alternative:
#   http://127.0.0.1:1234/v1 + text-embedding-nomic-embed-text-v1.5 (768-dim)
LLM_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_MODEL=BAAI/bge-m3

# --- RAG / Chroma ---
CHROMA_DB_PATH=./data/chroma
CHROMA_COLLECTION_NAME=finsight_cases
RAG_CASES_DIR=./backend/knowledge_base/cases

# --- Storage / misc ---
DB_PATH=./data/finsight.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
