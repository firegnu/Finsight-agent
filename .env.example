# --- Chat LLM (ReAct loop + structured report) ---
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen3.5-35b-a3b
MAX_AGENT_STEPS=10

# --- Embedding (RAG) ---
# Leave BASE_URL and API_KEY empty to reuse the chat ones (single LM Studio case).
# Set them separately when chat + embedding come from different providers,
# e.g. DeepSeek chat + dashscope embedding on a VPS deployment.
LLM_EMBEDDING_BASE_URL=
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# --- RAG / Chroma ---
CHROMA_DB_PATH=./data/chroma
CHROMA_COLLECTION_NAME=finsight_cases
RAG_CASES_DIR=./backend/knowledge_base/cases

# --- Storage / misc ---
DB_PATH=./data/finsight.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
